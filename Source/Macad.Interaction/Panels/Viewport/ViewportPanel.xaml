<mmp:AirspaceOverlay x:Class="Macad.Interaction.Panels.ViewportPanel"
                     x:Name="This"
                     xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                     xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                     xmlns:mmp="clr-namespace:Macad.Presentation;assembly=Macad.Presentation"
                     xmlns:panels="clr-namespace:Macad.Interaction.Panels"
                     mc:Ignorable="d" 
                     d:DesignHeight="300" d:DesignWidth="300" 
                     Focusable="True" 
                     SnapsToDevicePixels="True"
                     Background="{StaticResource Macad.Brushes.Window.Background}"
                     Cursor="{Binding Cursor}">

        <Grid>
            <Border x:Name="ViewContainer"
                    ForceCursor="True">

                <Grid x:Name="HudContainer" Visibility="Hidden"
                      HorizontalAlignment="Left" VerticalAlignment="Top"
                      IsSharedSizeScope="True">
                    <Border
                        Visibility="{Binding HudElements.Count, Converter={mmp:EqualityToInvisibleCollapsedConverter}, ConverterParameter=0}"
                        CornerRadius="3"
                        BorderThickness="0" 
                        BorderBrush="{StaticResource Macad.Brushes.HudElement.Border}"
                        Background="{StaticResource Macad.Brushes.HudElement.Background}"
                        Margin="20" Padding="5,2">

                        <mmp:TemplateItemsControl
                            ItemsSource="{Binding HudElements}" Foreground="White"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center">

                        </mmp:TemplateItemsControl>
                    </Border>
                </Grid>

            </Border>

            <!--region Viewports-->
            <mmp:TemplateItemsControl ItemsSource="{Binding ViewportDefinitions}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left"
                                Value="{Binding Left}" />

                        <Setter Property="Canvas.Top"
                                Value="{Binding Top}" />
                    </Style>
                </ItemsControl.ItemContainerStyle>

            <mmp:TemplateItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="{Binding Width}" 
                              Height="{Binding Height}" >

                            <mmp:OutlinedTextBlock Text="{Binding ViewportController.Label}"
                                                   Visibility="{Binding ViewportController.IsViewCubeVisible, Converter={mmp:BoolToInvisibleHiddenConverter}}"
                                                   FontSize="20"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Top"
                                                   Margin="20,10"
                                                   Fill="White"
                                                   Stroke="DimGray"
                                                   StrokePosition="Outside"
                                                   Opacity="0.7"/>

                            <panels:ViewportGridInfo Visibility="{Binding ViewportController.IsActive, Converter={mmp:BoolToVisibleCollapsedConverter}}"
                                                     VerticalContentAlignment="Bottom"
                                                     HorizontalAlignment="Right"
                                                     Margin="0,0,50,30" />

                        <Border x:Name="ActiveViewport"
                                    BorderThickness="2"
                                    BorderBrush="{StaticResource Macad.Brushes.Accent}">
                            <Border.Visibility>
                                <MultiBinding Converter="{mmp:BooleanAndToVisibleCollapsedMultiConverter}">
                                    <Binding Path="DataContext.HasMultipleViewports" RelativeSource="{RelativeSource AncestorType=mmp:TemplateItemsControl}" />
                                    <Binding Path="ViewportController.IsActive" />
                                </MultiBinding>
                            </Border.Visibility>
                        </Border>

                    </Grid>
                    </DataTemplate>
                </mmp:TemplateItemsControl.ItemTemplate>
            </mmp:TemplateItemsControl>
            <!--endregion-->

            <!-- Content from app -->
            <ContentPresenter x:Name="OverlayContentPresenter"  />
        </Grid>

</mmp:AirspaceOverlay>
